# Data Quality Agent — Environment Variables
# Copy this file to .env and fill in your values:  cp .env.example .env

# Application database (DQA tables — always PostgreSQL)
APP_DB_URL=postgresql+asyncpg://dqa:dqa_password@postgres:5432/dqa_app

# Data source (ERP data — PostgreSQL locally, Redshift in production)
DATA_SOURCE_URL=postgresql+asyncpg://dqa:dqa_password@postgres:5432/dqa_erp

# LLM provider: "anthropic", "openai", or "databricks"
MODEL_PROVIDER=anthropic

# Model name (e.g. claude-opus-4-6, gpt-4o, or your Databricks endpoint name)
MODEL_NAME=claude-sonnet-4-6

# Embeddings provider: "local" (default, fastembed), "openai", or "databricks"
EMBEDDINGS_PROVIDER=local

# Required when MODEL_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Required when MODEL_PROVIDER=openai or EMBEDDINGS_PROVIDER=openai
OPENAI_API_KEY=

# Required when MODEL_PROVIDER=databricks or EMBEDDINGS_PROVIDER=databricks
DATABRICKS_HOST=
DATABRICKS_TOKEN=

# Environment: "development" or "production"
ENV=development

# Postgres (used by docker-compose for container init)
POSTGRES_USER=dqa
POSTGRES_PASSWORD=dqa_password
